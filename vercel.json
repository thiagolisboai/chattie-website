{
  "rewrites": [
    {
      "source": "/pt-br/blog",
      "destination": "https://chattie-blog.vercel.app/pt-br/blog"
    },
    {
      "source": "/pt-br/blog/:path*",
      "destination": "https://chattie-blog.vercel.app/pt-br/blog/:path*"
    },
    {
      "source": "/blog",
      "destination": "https://chattie-blog.vercel.app/blog"
    },
    {
      "source": "/blog/:path*",
      "destination": "https://chattie-blog.vercel.app/blog/:path*"
    },
    {
      "source": "/_next/:path*",
      "destination": "https://chattie-blog.vercel.app/_next/:path*"
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://chattie-blog.vercel.app/sitemap.xml"
    },
    {
      "source": "/blog-robots.txt",
      "destination": "https://chattie-blog.vercel.app/robots.txt"
    },
    {
      "source": "/authors/:path*",
      "destination": "https://chattie-blog.vercel.app/authors/:path*"
    },
    {
      "source": "/brand/:path*",
      "destination": "https://chattie-blog.vercel.app/brand/:path*"
    },
    {
      "source": "/fonts/:path*",
      "destination": "https://chattie-blog.vercel.app/fonts/:path*"
